{
  "query": "\n-- 从订单表中统计老师在哪些城市授课\nSELECT \n  o.deliveryTeacher as teacher_name,\n  o.deliveryCity as city_name,\n  COUNT(*) as order_count\nFROM orders o\nWHERE o.deliveryTeacher IS NOT NULL \n  AND o.deliveryTeacher != ''\n  AND o.deliveryCity IS NOT NULL\n  AND o.deliveryCity != ''\nGROUP BY o.deliveryTeacher, o.deliveryCity\nORDER BY o.deliveryTeacher, order_count DESC\nLIMIT 30;\n",
