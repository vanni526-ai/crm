{
  "query": "\nSELECT \n  p.id as partner_id,\n  p.name as partner_name,\n  c.name as city_name,\n  pc.id as partner_city_id,\n  COUNT(o.id) as order_count\nFROM partners p\nLEFT JOIN partner_cities pc ON p.id = pc.partnerId\nLEFT JOIN cities c ON pc.cityId = c.id\nLEFT JOIN orders o ON c.name = o.deliveryCity\nGROUP BY p.id, p.name, c.name, pc.id\nORDER BY order_count ASC, p.id, c.name;\n",
