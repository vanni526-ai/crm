{
  "query": "\n-- 查询所有激活的partners记录及其关联的城市\nSELECT \n  p.id as partnerId,\n  p.userId,\n  p.name as partnerName,\n  p.phone as partnerPhone,\n  p.isActive,\n  p.createdAt,\n  pc.id as partnerCityId,\n  pc.cityId,\n  c.name as cityName,\n  pc.contractStatus,\n  u.name as userName,\n  u.phone as userPhone,\n  u.isActive as userIsActive\nFROM partners p\nLEFT JOIN partner_cities pc ON pc.partnerId = p.id AND pc.contractStatus = 'active'\nLEFT JOIN cities c ON c.id = pc.cityId\nLEFT JOIN users u ON u.id = p.userId\nWHERE p.isActive = true\nORDER BY p.createdAt DESC\nLIMIT 20;\n",
