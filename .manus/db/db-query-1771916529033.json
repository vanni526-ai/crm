{
  "query": "SELECT p.id, p.name, p.isActive, p.createdAt,\n       COUNT(pc.id) as city_count,\n       GROUP_CONCAT(DISTINCT c.name) as cities,\n       GROUP_CONCAT(DISTINCT pc.contractStatus) as contract_statuses\nFROM partners p\nLEFT JOIN partner_cities pc ON p.id = pc.partnerId\nLEFT JOIN cities c ON pc.cityId = c.id\nWHERE p.isActive = 1\nGROUP BY p.id, p.name, p.isActive, p.createdAt\nHAVING city_count > 0\nORDER BY p.id;",
